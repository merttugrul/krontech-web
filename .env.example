# ─────────────────────────────────────
# Database (PostgreSQL)
# Container içi: postgres:5432  |  Host'tan (lokal CLI/IDE): localhost:5433
# Docker compose içinde environment override eder; .env içindeki değer host'tan
# Prisma CLI çalıştırırken kullanılır.
# ─────────────────────────────────────
DATABASE_URL=postgresql://krontech:password@localhost:5433/krontech

# ─────────────────────────────────────
# Redis
# Container içi: redis:6379  |  Host'tan: localhost:6380
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_SECRET=supersecretjwtkey_change_me_in_prod
JWT_REFRESH_SECRET=supersecretrefreshkey_change_me_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────
# S3 / MinIO
# ─────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
# Docker Compose ağı içinde frontend (next/image) ve backend MinIO için servis hostname'i
S3_PUBLIC_ENDPOINT=http://minio:9000
S3_BUCKET=krontech-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ─────────────────────────────────────
# reCAPTCHA (Google reCAPTCHA v3 — formlar executeRecaptcha kullanır)
# ─────────────────────────────────────
RECAPTCHA_SECRET=your_recaptcha_secret_here
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ─────────────────────────────────────
# Next.js
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
REVALIDATION_SECRET=revalidationsecret_change_me

# ─────────────────────────────────────
# Backend
# ─────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────
# Admin Seed (ilk kurulumda oluşturulur)
# ─────────────────────────────────────
ADMIN_EMAIL=admin@krontech.com
ADMIN_PASSWORD=Admin123!
