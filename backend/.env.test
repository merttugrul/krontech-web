# Test ortamı için environment — asla üretim/dev ile karışmamalı.
# Jest globalSetup bu dosyayı otomatik yükler.

NODE_ENV=test

# Test DB — ayrı database, aynı Postgres container
DATABASE_URL=postgresql://krontech:password@localhost:5433/krontech_test?schema=public

# Redis — aynı instance, ayrı database index (0=dev, 1=test)
REDIS_URL=redis://localhost:6380/1

# JWT — test için sabit secret, deterministik token üretimi
JWT_SECRET=test-jwt-secret-not-for-production
JWT_REFRESH_SECRET=test-jwt-refresh-secret-not-for-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# S3 / MinIO — testlerde mocklanacak, yine de doldurulmalı (env validation)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=krontech_dev
S3_SECRET_KEY=krontech_dev_password
S3_BUCKET=krontech-media-test
S3_REGION=us-east-1

# reCAPTCHA — test key'i (Google dokümantasyonundan always-pass)
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# Frontend — test için dummy
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_REVALIDATE_SECRET=test-revalidate-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend port
PORT=4001

# Admin seed
ADMIN_EMAIL=admin@krontech.com
ADMIN_PASSWORD=Admin123!
