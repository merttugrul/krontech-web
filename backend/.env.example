# ─────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/krontech

# ─────────────────────────────────────
# Redis
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────
# S3 / MinIO
# ─────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=krontech-media
S3_ACCESS_KEY=your-minio-access-key-id
S3_SECRET_KEY=your-minio-secret-access-key
S3_REGION=us-east-1

# ─────────────────────────────────────
# reCAPTCHA (Google reCAPTCHA v2)
# ─────────────────────────────────────
RECAPTCHA_SECRET=your-recaptcha-secret-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ─────────────────────────────────────
# Next.js
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
REVALIDATION_SECRET=your-on-demand-revalidation-secret

# ─────────────────────────────────────
# Backend
# ─────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────
# Admin Seed (ilk kurulumda oluşturulur)
# ─────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
