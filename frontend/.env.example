# Backend REST API — server-side fetch + client axios instance buradan çeker.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Kendi origin'imiz — OG meta, metadataBase, sitemap URL inşası için.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google reCAPTCHA v3 site key — contact form için client tarafı.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Backend ile paylaşılan secret. Backend revalidate çağırdığında body'deki
# secret'ı bununla karşılaştırırız. ASLA NEXT_PUBLIC_ prefix'i verme.
REVALIDATION_SECRET=revalidationsecret_change_me
